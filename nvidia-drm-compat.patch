 				       u32 id);
--- a/drivers/gpu/drm/drm_framebuffer.c
+++ b/drivers/gpu/drm/drm_framebuffer.c
@@ -164,7 +164,11 @@ EXPORT_SYMBOL(drm_framebuffer_lookup);
  * Fills out @mode_cmd from the buffer object properties, and if the driver
  * supports format modifiers, also from @mode_cmd itself.
  */
+#ifdef CONFIG_DRM_NVIDIA_COMPAT
+struct drm_framebuffer *nvidia_drm_helper_mode_fill_fb_struct(struct drm_device *dev,
+						    struct drm_mode_fb_cmd2 *mode_cmd)
+#else
 void drm_helper_mode_fill_fb_struct(struct drm_device *dev,
 				    struct drm_mode_fb_cmd2 *mode_cmd)
+#endif
 {
 	struct drm_framebuffer *fb;
 	const struct drm_format_info *info;
@@ -202,6 +206,15 @@ void drm_helper_mode_fill_fb_struct(struct drm_device *dev,
 	fb->height = mode_cmd->height;
 	fb->modifier = mode_cmd->modifier[0];
 	fb->flags = mode_cmd->flags;
+
+#ifdef CONFIG_DRM_NVIDIA_COMPAT
+	return fb;
+#endif
 }
+
+#ifdef CONFIG_DRM_NVIDIA_COMPAT
+EXPORT_SYMBOL_GPL(nvidia_drm_helper_mode_fill_fb_struct);
+#endif
