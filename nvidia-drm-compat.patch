diff --git a/drivers/gpu/drm/Kconfig b/drivers/gpu/drm/Kconfig
index abc123..def456 100644
--- a/drivers/gpu/drm/Kconfig
+++ b/drivers/gpu/drm/Kconfig
@@ -55,6 +55,16 @@ config DRM_DEBUG_MM
 		DRM_DEBUG_MM is enabled, and it will affect the
 		performance.
 
+config DRM_NVIDIA_COMPAT
+	bool "NVIDIA Driver 570.xx Compatibility"
+	default y
+	help
+	  Enable backward compatibility for NVIDIA proprietary drivers
+	  version 570.xx and older. These drivers use an older DRM API
+	  that was changed in kernel 6.17. Enable this if you use
+	  NVIDIA drivers 570.153.02 or older.
+
+	  If unsure, say Y.
+
 source "drivers/gpu/drm/i2c/Kconfig"
 
 source "drivers/gpu/drm/arm/Kconfig"
diff --git a/include/drm/drm_framebuffer.h b/include/drm/drm_framebuffer.h
index abc123..def456 100644
--- a/include/drm/drm_framebuffer.h
+++ b/include/drm/drm_framebuffer.h
@@ -55,6 +55,19 @@ struct drm_framebuffer_funcs {
 	struct drm_gem_object *(*get_scanout_obj)(struct drm_framebuffer *fb);
 };
 
+/* NVIDIA Driver 570.xx compatibility for kernel 6.17+
+ * The NVIDIA driver expects the old API without format_info parameter.
+ * This compatibility macro provides backward compatibility.
+ */
+#ifndef DRM_FORMAT_INFO_FOR_NVIDIA
+#define DRM_FORMAT_INFO_FOR_NVIDIA
+static inline const struct drm_format_info *drm_mode_fb_get_format_info(
+				const struct drm_mode_fb_cmd2 *cmd)
+{
+	return drm_format_info(cmd->pixel_format);
+}
+#endif
+
 struct drm_framebuffer *drm_framebuffer_lookup(struct drm_device *dev,
 				       struct drm_file *file_priv,
 				       u32 id);
diff --git a/drivers/gpu/drm/drm_framebuffer.c b/drivers/gpu/drm/drm_framebuffer.c
index abc123..def456 100644
--- a/drivers/gpu/drm/drm_framebuffer.c
+++ b/drivers/gpu/drm/drm_framebuffer.c
@@ -164,7 +164,15 @@ EXPORT_SYMBOL(drm_framebuffer_lookup);
  * Fills out @mode_cmd from the buffer object properties, and if the driver
  * supports format modifiers, also from @mode_cmd itself.
  */
+#ifdef CONFIG_DRM_NVIDIA_COMPAT
+struct drm_framebuffer *drm_helper_mode_fill_fb_struct(struct drm_device *dev,
+						       struct drm_mode_fb_cmd2 *mode_cmd,
+						       const struct drm_format_info *format_info)
+#else
 void drm_helper_mode_fill_fb_struct(struct drm_device *dev,
 				    struct drm_mode_fb_cmd2 *mode_cmd)
+#endif
 {
 	struct drm_framebuffer *fb;
 	const struct drm_format_info *info;
@@ -202,6 +210,11 @@ void drm_helper_mode_fill_fb_struct(struct drm_device *dev,
 	fb->height = mode_cmd->height;
 	fb->modifier = mode_cmd->modifier[0];
 	fb->flags = mode_cmd->flags;
+
+#ifdef CONFIG_DRM_NVIDIA_COMPAT
+	return fb;
+#endif
 }
+#ifdef CONFIG_DRM_NVIDIA_COMPAT
+EXPORT_SYMBOL_GPL(drm_helper_mode_fill_fb_struct);
+#endif
 
