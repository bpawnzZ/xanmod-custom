 };
 
+/* NVIDIA Driver 570.xx compatibility for kernel 6.17+ */
+#ifdef CONFIG_DRM_NVIDIA_COMPAT
+static inline const struct drm_format_info *nvidia_drm_get_format_info(
+				const struct drm_mode_fb_cmd2 *cmd)
+{
+	return drm_format_info(cmd->pixel_format);
+}
+
+struct drm_framebuffer *nvidia_drm_helper_mode_fill_fb_struct(
+				struct drm_device *dev,
+				struct drm_mode_fb_cmd2 *mode_cmd);
+#endif
+
